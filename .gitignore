.DS_Store
.DS_Store?
._*

# ── Python bytecode & caches ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
.citnega_env/

# ── Build & distribution ───────────────────────────────────────────────────────
*.egg-info/
dist/
build/
*.whl
*.tar.gz
MANIFEST

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
