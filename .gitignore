*.testmondata

# ── Type checking & linting ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.dmypy.json

# ── Secrets and environment files ─────────────────────────────────────────────
.env
.env.*
*.env
!.env.example

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Local databases (dev/test artifacts — not workfolder data) ────────────────
*.sqlite
*.sqlite3
*.db

# ── Tool caches ───────────────────────────────────────────────────────────────
.citnega_cache/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

